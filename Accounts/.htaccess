DirectoryIndex index.php

<IfModule mod_rewrite.c>
RewriteEngine On

# 1. Rule for Invoices (with /invoice/<token>)
RewriteRule ^invoice/([a-zA-Z0-9_-]+)$ api/view_invoice.php?token=$1 [QSA,L]

# 2. Rule for Receipts (with /receipt/<token>)
RewriteRule ^receipt/([a-zA-Z0-9_-]+)$ api/view_receipt.php?token=$1 [QSA,L]
</IfModule>
